APP_NAME="Operations Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Default DB for app. Tests use in-memory sqlite (see phpunit.xml).
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=oms
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

# Queue: redis preferred (System Design), fallback database.
QUEUE_CONNECTION=database
CACHE_STORE=database
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# --- NEVIRA (OPS-102/108) — secret store / .env, never committed ---
NEVIRA_BASE_URL=
NEVIRA_SERVICE_USERNAME=
NEVIRA_SERVICE_PASSWORD=
